# CUURS Backend Configuration
# Copy this file to .env and update the values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cuurs_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_random_and_long

# Africa's Talking API (for SMS)
AFRICA_TALKING_API_KEY=your_api_key_here
AFRICA_TALKING_USERNAME=your_username_here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# SMS Configuration
SMS_SENDER_ID=CUURS
SMS_ALERT_MAX_LENGTH=160
